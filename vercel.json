{
  "cleanUrls": true,
  "outputDirectory": "build",
  "redirects": [
    {
      "source": "/cloud/latest/",
      "destination": "/cloud/26.8.0.cl/",
      "statusCode": 301 },
    {
      "source": "/cloud/latest",
      "destination": "/cloud/26.8.0.cl/",
      "statusCode": 301 },
    {
      "source": "/cloud/latest/:path*",
      "destination": "/cloud/26.8.0.cl/:path*",
      "statusCode": 301 },
    {
      "source": "/cloud/26.8.0.cl",
      "destination": "/cloud/26.8.0.cl/",
      "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-eval' 'unsafe-inline' data: filesystem: about: blob:;"
        }
      ]
    }
  ]
}
